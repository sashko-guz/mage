# =============================================================================
# Storage Configuration
# =============================================================================

# Storage driver: local or s3
STORAGE_DRIVER=local

# Local storage root directory (required for local driver)
STORAGE_ROOT=/absolute/path/to/original/images

# S3 storage configuration (required for s3 driver)
S3_BUCKET=
S3_REGION=us-east-1
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BASE_URL=
S3_USE_PATH_STYLE=false

# S3 HTTP tuning
S3_MAX_IDLE_CONNS=100
S3_MAX_IDLE_CONNS_PER_HOST=100
S3_MAX_CONNS_PER_HOST=0
S3_IDLE_CONN_TIMEOUT_SEC=90
S3_CONNECT_TIMEOUT_SEC=10
S3_REQUEST_TIMEOUT_SEC=30
S3_RESPONSE_HEADER_TIMEOUT_SEC=10

# =============================================================================
# Cache Configuration (SOURCE_ for source images, THUMB_ for thumbnails)
# =============================================================================

# Memory cache
SOURCE_MEMORY_CACHE_ENABLED=false
SOURCE_MEMORY_CACHE_MAX_SIZE_MB=256
SOURCE_MEMORY_CACHE_MAX_ITEMS=1000
SOURCE_MEMORY_CACHE_TTL_SEC=300

THUMB_MEMORY_CACHE_ENABLED=false
THUMB_MEMORY_CACHE_MAX_SIZE_MB=256
THUMB_MEMORY_CACHE_MAX_ITEMS=1000
THUMB_MEMORY_CACHE_TTL_SEC=300

# Disk cache
SOURCE_DISK_CACHE_ENABLED=false
SOURCE_DISK_CACHE_DIR=
SOURCE_DISK_CACHE_MAX_SIZE_MB=2048
SOURCE_DISK_CACHE_MAX_ITEMS=100000
SOURCE_DISK_CACHE_TTL_SEC=600
SOURCE_DISK_CACHE_CLEAR_ON_STARTUP=false
SOURCE_DISK_CACHE_ASYNC_ENABLED=true
SOURCE_DISK_CACHE_ASYNC_WORKERS=4
SOURCE_DISK_CACHE_ASYNC_QUEUE_SIZE=1000

THUMB_DISK_CACHE_ENABLED=false
THUMB_DISK_CACHE_DIR=
THUMB_DISK_CACHE_MAX_SIZE_MB=2048
THUMB_DISK_CACHE_MAX_ITEMS=100000
THUMB_DISK_CACHE_TTL_SEC=600
THUMB_DISK_CACHE_CLEAR_ON_STARTUP=false
THUMB_DISK_CACHE_ASYNC_ENABLED=true
THUMB_DISK_CACHE_ASYNC_WORKERS=4
THUMB_DISK_CACHE_ASYNC_QUEUE_SIZE=1000

# =============================================================================
# Server Configuration
# =============================================================================

PORT=8080
LOG_LEVEL=error

# HTTP timeouts (seconds)
HTTP_READ_TIMEOUT_SECONDS=5
HTTP_READ_HEADER_TIMEOUT_SECONDS=2
HTTP_WRITE_TIMEOUT_SECONDS=30
HTTP_IDLE_TIMEOUT_SECONDS=120
HTTP_MAX_HEADER_BYTES=1048576

# =============================================================================
# CORS Configuration
# =============================================================================

CORS_ALLOW_ORIGIN=*
CORS_ALLOW_METHODS=GET, HEAD, OPTIONS
CORS_ALLOW_HEADERS=Origin, Content-Type, Accept, Authorization
CORS_EXPOSE_HEADERS=Content-Type, Content-Length, Cache-Control, X-Mage-Cache
CORS_MAX_AGE=86400

# =============================================================================
# Signature Configuration (optional, for URL signing)
# =============================================================================

SIGNATURE_SECRET=
SIGNATURE_ALGO=sha256
SIGNATURE_EXTRACT_START=0
SIGNATURE_LENGTH=16

# =============================================================================
# Image Processing Limits
# =============================================================================

MAX_INPUT_IMAGE_SIZE_MB=64
MAX_RESIZE_WIDTH=5120
MAX_RESIZE_HEIGHT=5120
MAX_RESIZE_RESOLUTION=26214400

# =============================================================================
# Response Headers
# =============================================================================

CACHE_CONTROL_RESPONSE_HEADER=public, max-age=31536000, immutable

# =============================================================================
# Observability
# =============================================================================

METRICS_ENABLED=true
METRICS_PATH=/metrics
HEALTH_READINESS_TIMEOUT_SECONDS=5
